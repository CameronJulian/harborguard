type CommandCenterGeofence = {
  id: string;
  name: string;
  center_lat: number;
  center_lng: number;
  radius_meters: number;
  is_active: boolean;
};

type FleetAlert = {
  id?: string;
  alert_type?: string | null;
  severity?: string | null;
  message?: string | null;
