            background:
              threat.level === "Critical"
                ? "#fff5f5"
                : threat.level === "High"
                ? "#fff7ed"
                : "#ffffff",
          }}
        >
          <div
            style={{
              display: "flex",
              justifyContent: "space-between",
              gap: 20,
              flexWrap: "wrap",
            }}
          >
            <div>
              <div
                style={{
                  fontSize: 22,
                  fontWeight: 900,
                }}
              >
                {threat.registrationNumber}
              </div>

              <div style={{ color: "#64748b" }}>
                {threat.nickname || "Fleet Vehicle"}
              </div>
            </div>

            <div>
              <div
                style={{
                  color: "#64748b",
                  fontSize: 13,
                }}
              >
                Threat Probability
              </div>

              <div
                style={{
                  fontSize: 36,
                  fontWeight: 900,
                  color:
                    threat.level === "Critical"
                      ? "#dc2626"
                      : threat.level === "High"
                      ? "#ea580c"
                      : threat.level === "Medium"
                      ? "#d97706"
                      : "#16a34a",
                }}
              >
                {threat.probability}%
              </div>
            </div>
          </div>

          <div
            style={{
              marginTop: 14,
              display: "grid",
              gap: 6,
              color: "#475569",
              fontSize: 14,
            }}
          >
            <div>Ã¢â‚¬Â¢ Speed: {threat.speed} km/h</div>
            <div>Ã¢â‚¬Â¢ Open Alerts: {threat.openAlerts}</div>
            <div>
              Ã¢â‚¬Â¢ Critical Alerts: {threat.criticalAlerts}
            </div>
            <div>
              Ã¢â‚¬Â¢ Near Incident Zone:{" "}
              {threat.nearIncident ? "Yes" : "No"}
            </div>
            <div>
              Ã¢â‚¬Â¢ Offline: {threat.isOffline ? "Yes" : "No"}
            </div>
          </div>
        </div>
      ))}
    </div>
  )}
</div>

        <div
          style={{
            ...cardStyle,
            padding: 22,
            marginBottom: 24,
